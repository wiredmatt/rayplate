{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "desktop-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "GAME_ANGLE_PROVIDER": "DOWNLOAD"
      }
    },
    {
      "name": "desktop-debug",
      "inherits": "desktop-base",
      "displayName": "Desktop debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "desktop-release",
      "inherits": "desktop-base",
      "displayName": "Desktop release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "desktop-sanitize",
      "inherits": "desktop-base",
      "displayName": "Desktop debug with sanitizers",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "GAME_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "desktop-no-angle",
      "inherits": "desktop-base",
      "displayName": "Desktop debug without ANGLE",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "GAME_ANGLE_PROVIDER": "OFF"
      }
    },
    {
      "name": "web-release",
      "displayName": "Emscripten web release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PLATFORM": "Web"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "desktop-debug",
      "configurePreset": "desktop-debug"
    },
    {
      "name": "desktop-release",
      "configurePreset": "desktop-release"
    },
    {
      "name": "desktop-sanitize",
      "configurePreset": "desktop-sanitize"
    },
    {
      "name": "desktop-no-angle",
      "configurePreset": "desktop-no-angle"
    },
    {
      "name": "web-release",
      "configurePreset": "web-release"
    }
  ],
  "testPresets": [
    {
      "name": "desktop-debug",
      "configurePreset": "desktop-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "desktop-release",
      "configurePreset": "desktop-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "desktop-sanitize",
      "configurePreset": "desktop-sanitize",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}